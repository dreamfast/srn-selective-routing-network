# GPU selection — which GPU(s) the container can see
# Examples:
#   NVIDIA_GPU=all        (all GPUs)
#   NVIDIA_GPU=0          (first GPU only)
#   NVIDIA_GPU=1          (second GPU only)
#   NVIDIA_GPU=0,1        (both GPUs)
NVIDIA_GPU=all

# HuggingFace token — needed for gated datasets/models
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=
